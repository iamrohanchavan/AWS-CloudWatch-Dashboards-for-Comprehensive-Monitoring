{
  "widgets": [

    {
      "type": "metric",
      "x": 0,
      "y": 0,
      "width": 12,
      "height": 6,
      "properties": {
        "metrics": [
          [ "AWS/Billing", "EstimatedCharges", "ServiceName", "AmazonEC2" ],
          [ "AWS/Billing", "EstimatedCharges", "ServiceName", "AmazonS3" ]
        ],
        "view": "timeSeries",
        "region": "us-east-1",
        "title": "Estimated AWS Charges (EC2 & S3)"
      }
    },

    {
      "type": "log",
      "x": 0,
      "y": 7,
      "width": 12,
      "height": 6,
