          [ "AWS/EC2", "NetworkIn" ],
          [ "AWS/EC2", "NetworkOut" ]
        ],
        "view": "timeSeries",
        "region": "ap-south-1",
        "title": "EC2 Network Performance"
      }
    },

    {
      "type": "metric",
      "x": 0,
